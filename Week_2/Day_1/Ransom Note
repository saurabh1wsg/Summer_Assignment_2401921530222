class Solution {
public:
    bool canConstruct(string ransomNote, string magazine) {
        vector<int> freq(26, 0);

        for (char c : magazine) {
            freq[c - 'a']++;
        }

        for (char c : ransomNote) {
            if (freq[c - 'a'] == 0) {
                return false;
            }
            freq[c - 'a']--;
        }

        return true;
    }
};

int main() {
    Solution obj;
    string ransomNote = "aa";
    string magazine = "aab";

    cout << obj.canConstruct(ransomNote, magazine) << endl;

    return 0;
}
